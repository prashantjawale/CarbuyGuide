      "question": "Any fuel type preference?",
      "type": "multiChoice",
      "maxSelections": 3,
      "options": [
        { "label": "Petrol (no preference)", "value": "Petrol", "tags": [] },
        {
          "label": "Diesel (long distance)",
          "value": "Diesel",
          "tags": ["diesel"]
        },
        {
          "label": "Electric (eco-conscious)",
          "value": "Electric",
          "tags": ["electric", "eco"]
        },
        {
          "label": "Hybrid (best of both)",
          "value": "Hybrid Petrol",
          "tags": ["hybrid"]
        },
        {
          "label": "CNG (lowest running cost)",
          "value": "CNG",
          "tags": ["cng"]
        },
        { "label": "No preference", "value": "any", "tags": [] }
      ],
      "usedFor": ["filtering", "scoring"]
    },
    {
      "id": "financing",
      "question": "How are you planning to pay?",
      "type": "singleChoice",
      "options": [
        { "label": "Full cash / no loan", "value": "cash" },
        { "label": "Car loan (I'll share details)", "value": "loan" }
      ],
      "usedFor": ["emiCalc"]
    },
    {
      "id": "loanDetails",
      "question": "Loan details",
      "type": "loanInput",
      "showIf": { "financing": "loan" },
      "fields": {
        "downPaymentPercent": { "default": 20, "min": 10, "max": 50 },
        "tenureMonths": { "options": [36, 48, 60, 72, 84], "default": 60 },
        "interestRate": { "default": 8.75, "min": 7.0, "max": 14.0 }
      },
      "usedFor": ["emiCalc"]
    },
    {
      "id": "dealbreakers",
      "question": "Any absolute deal-breakers?",
      "type": "multiChoice",
      "maxSelections": 5,
      "optional": true,
      "options": [
        {
          "label": "No AMT gearbox",
          "value": "noAMT",
          "excludeTransmission": ["AMT"]
        },
        {
          "label": "No less than 4-star safety",
          "value": "minSafety4",
          "minSafetyRating": 4
        },
        {
          "label": "No less than 5-star safety",
          "value": "minSafety5",
          "minSafetyRating": 5
        },
        {
          "label": "Must have sunroof",
          "value": "needSunroof",
          "requireFeature": "Sunroof"
        },
        {
          "label": "Must have ADAS",
          "value": "needADAS",
          "requireFeature": "ADAS"
        },
        {
          "label": "No diesel",
          "value": "noDiesel",
          "excludeFuel": ["Diesel"]
        },
        { "label": "Minimum 7 seats", "value": "min7Seats", "minSeats": 7 },
        {
          "label": "Must have 4WD/AWD",
          "value": "need4WD",
          "requireFeature": "4WD"
        }
      ],
      "usedFor": ["filtering"]
    }
